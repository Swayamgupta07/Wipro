<%- include('partials/header') %>

<div class="row mb-4 align-items-center">
  <div class="col-md-6">
    <h2 class="section-title">Students Directory</h2>
  </div>
  <div class="col-md-6">
    <form action="/students" method="GET">
      <div class="search-bar-container">
        <i class="bi bi-search search-icon"></i>
        <input 
          type="text" 
          name="search" 
          value="<%= search %>" 
          class="form-control search-input" 
          placeholder="Search by Name, Course or City..."
        >
        <% if (search) { %>
          <a href="/students" class="btn btn-sm btn-link position-absolute end-0 top-50 translate-middle-y me-2 text-muted" style="z-index: 10;">
            <i class="bi bi-x-circle-fill"></i> Clear
          </a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<% if (success && success.length > 0) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (error && error.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<!-- Main Table Card -->
<div class="dashboard-card p-0">
  <% if (students && students.length > 0) { %>
    <div class="table-responsive-container">
      <table class="table table-custom align-middle">
        <thead>
          <tr>
            <th>Roll No.</th>
            <th>Name</th>
            <th>Course</th>
            <th>Age</th>
            <th>Email</th>
            <th>City</th>
            <th class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(student => { %>
            <tr>
              <td class="fw-bold text-secondary">#<%= student.rollno %></td>
              <td class="fw-semibold"><%= student.name %></td>
              <td>
                <span class="badge badge-custom badge-course">
                  <%= student.course %>
                </span>
              </td>
              <td><%= student.age %> yrs</td>
              <td>
                <a href="mailto:<%= student.email %>" class="text-decoration-none text-secondary">
                  <i class="bi bi-envelope me-1"></i> <%= student.email %>
                </a>
              </td>
              <td>
                <span class="badge badge-custom badge-city">
                  <i class="bi bi-geo-alt-fill me-1"></i> <%= student.city %>
                </span>
              </td>
              <td class="text-center">
                <div class="d-flex justify-content-center gap-2">
                  <a href="/students/view/<%= student._id %>" class="action-btn action-btn-view" title="View Profile">
                    <i class="bi bi-eye-fill"></i>
                  </a>
                  <a href="/students/edit/<%= student._id %>" class="action-btn action-btn-edit" title="Edit Student">
                    <i class="bi bi-pencil-fill"></i>
                  </a>
                  <a href="/students/delete/<%= student._id %>" 
                     class="action-btn action-btn-delete" 
                     title="Delete Record"
                     onclick="return confirm('Are you sure you want to permanently delete student <%= student.name %>?');">
                    <i class="bi bi-trash-fill"></i>
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <!-- Empty State -->
    <div class="text-center py-5">
      <div class="mb-3">
        <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
      </div>
      <h4>No Students Found</h4>
      <p class="text-muted px-3">We couldn't find any student records matching your query. Try adding a new student or widening your search.</p>
      <% if (search) { %>
        <a href="/students" class="btn btn-secondary-gradient mt-2">
          <i class="bi bi-arrow-left me-1"></i> View All Students
        </a>
      <% } else { %>
        <a href="/students/add" class="btn btn-primary-gradient mt-2">
          <i class="bi bi-person-plus-fill me-1"></i> Add First Student
        </a>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
