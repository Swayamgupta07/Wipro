<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8 col-md-10">
    
    <div class="d-flex align-items-center mb-4">
      <a href="/students" class="btn btn-sm btn-light border me-3 rounded-3 px-3 py-2 text-secondary">
        <i class="bi bi-arrow-left"></i> Back to Directory
      </a>
      <h2 class="m-0 font-weight-700">Student Profile</h2>
    </div>

    <!-- Student Profile Card -->
    <div class="dashboard-card p-0 overflow-hidden">
      <!-- Profile Header Gradient -->
      <div class="profile-header">
        <div class="profile-avatar">
          <i class="bi bi-person-fill text-white"></i>
        </div>
        <div>
          <h3 class="m-0 fw-bold"><%= student.name %></h3>
          <p class="m-0 opacity-75">Roll Number: #<%= student.rollno %></p>
        </div>
      </div>

      <!-- Profile Details Body -->
      <div class="profile-body">
        <div class="detail-row">
          <div class="detail-label">Full Name</div>
          <div class="detail-val text-capitalize"><%= student.name %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Roll Number</div>
          <div class="detail-val">#<%= student.rollno %></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Course / Program</div>
          <div class="detail-val">
            <span class="badge badge-custom badge-course">
              <%= student.course %>
            </span>
          </div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Age</div>
          <div class="detail-val"><%= student.age %> years old</div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Email Address</div>
          <div class="detail-val">
            <a href="mailto:<%= student.email %>" class="text-decoration-none fw-semibold" style="color: #4f46e5;">
              <%= student.email %>
            </a>
          </div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Current City</div>
          <div class="detail-val">
            <span class="badge badge-custom badge-city">
              <i class="bi bi-geo-alt-fill me-1"></i> <%= student.city %>
            </span>
          </div>
        </div>

        <hr class="my-4 text-muted">

        <!-- Action Links -->
        <div class="d-flex justify-content-between align-items-center">
          <a href="/students/delete/<%= student._id %>" 
             class="btn btn-danger-gradient d-inline-flex align-items-center gap-2"
             onclick="return confirm('Are you sure you want to permanently delete student <%= student.name %>?');">
            <i class="bi bi-trash3-fill"></i> Delete Record
          </a>
          <a href="/students/edit/<%= student._id %>" class="btn btn-primary-gradient d-inline-flex align-items-center gap-2">
            <i class="bi bi-pencil-square"></i> Edit Information
          </a>
        </div>

      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
